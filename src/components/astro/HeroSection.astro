---
import { Linkedin, Github, Mail, ChevronDown, Code2 } from 'lucide-react';
import { personalInfo } from '../../data/portfolioData';
---

<section id="home" class="min-h-screen flex items-center justify-center px-6 pt-20">
  <div class="max-w-6xl mx-auto w-full">
    <div class="flex flex-col md:flex-row items-center justify-between gap-12">
      {/* Left Content */}
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-2">
          <span class="text-gray-900 dark:text-white">Hola, </span>
          <span class="text-cyan-600 dark:text-cyan-400">soy {personalInfo.name}</span>
        </h1>
        <p class="text-xl md:text-2xl mb-6 text-gray-600 dark:text-gray-400">
          {personalInfo.title}
        </p>
        <p class="mb-2 text-lg leading-relaxed text-gray-700 dark:text-gray-300">
          <span class="font-semibold text-cyan-600 dark:text-cyan-400">
            {personalInfo.yearsExperience} años de experiencia.
          </span>{' '}
          <span class="text-cyan-600 dark:text-cyan-400">Estudiante de Analista de Sistemas</span>{' '}
          <span class="text-gray-700 dark:text-gray-300">y</span>{' '}
          <span class="text-cyan-600 dark:text-cyan-400">Desarrollador Fullstack</span>.{' '}
          <span class="text-gray-500 dark:text-gray-400">
            {personalInfo.heroSubtitle}
          </span>
        </p>

        {/* Action Buttons */}
        <div class="flex flex-wrap gap-3 mt-8 justify-center md:justify-start">
          <a
            href={personalInfo.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2.5 border rounded-full text-sm transition-all bg-white border-gray-300 text-gray-700 hover:bg-gray-50 hover:border-gray-400 dark:bg-gray-800/80 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700 dark:hover:border-gray-600"
          >
            <Linkedin size={16} />
            LinkedIn
          </a>
          <a
            href={personalInfo.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2.5 border rounded-full text-sm transition-all bg-white border-gray-300 text-gray-700 hover:bg-gray-50 hover:border-gray-400 dark:bg-gray-800/80 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700 dark:hover:border-gray-600"
          >
            <Github size={16} />
            GitHub
          </a>
          <a
            href={`mailto:${personalInfo.email}`}
            class="flex items-center gap-2 px-4 py-2.5 border rounded-full text-sm transition-all bg-white border-gray-300 text-gray-700 hover:bg-gray-50 hover:border-gray-400 dark:bg-gray-800/80 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700 dark:hover:border-gray-600"
          >
            <Mail size={16} />
            {personalInfo.email}
          </a>
          <a
            href="#proyectos"
            class="flex items-center gap-2 px-4 py-2.5 border rounded-full text-sm transition-all bg-white border-gray-300 text-gray-700 hover:bg-gray-50 hover:border-gray-400 dark:bg-gray-800/80 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700 dark:hover:border-gray-600"
          >
            <Code2 size={16} className="text-cyan-600 dark:text-cyan-400" />
            Proyectos
          </a>
        </div>
      </div>

      {/* Right - Profile Image */}
      <div class="flex-shrink-0">
        <div class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden border-4 shadow-2xl relative border-cyan-500/40 shadow-cyan-500/30 dark:border-cyan-400/30 dark:shadow-cyan-500/20">
          <img
            src={personalInfo.profileImage}
            alt={`${personalInfo.fullName} - ${personalInfo.title}`}
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-tr from-cyan-500/10 to-purple-500/10 pointer-events-none" />
        </div>
      </div>
    </div>

    {/* Scroll Indicator */}
    <div class="flex justify-center mt-16">
      <a
        href="#experiencia"
        class="flex flex-col items-center transition-colors animate-bounce text-cyan-600 hover:text-cyan-500 dark:text-cyan-400 dark:hover:text-cyan-300"
      >
        <span class="text-sm mb-2">Experiencia</span>
        <ChevronDown size={20} />
      </a>
    </div>
  </div>
</section>
